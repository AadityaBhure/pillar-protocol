# Pillar Protocol Environment Variables

# Gemini AI API Key (Required)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration (Required for production)
# Get from: https://supabase.com/dashboard → Your Project → Settings → API

# Your Supabase project URL
SUPABASE_URL=https://your-project-id.supabase.co

# IMPORTANT: Use the SERVICE ROLE key, NOT the anon/publishable key!
# The service_role key starts with "eyJ" and is much longer
# Find it in: Settings → API → Project API keys → service_role (secret)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_service_role_key_here

# Note: The publishable key (sb_publishable_...) has limited permissions
# and won't work for server-side operations. Always use service_role key.
